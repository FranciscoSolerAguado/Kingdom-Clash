    - target: {fileID: 2326376749949932672, guid: 871c37401aa344d4a9b0c1f25390690b, type: 3}
      propertyPath: m_text
      value: "A pesar de las victorias en batallas pasadas el enemigo nos supera
        en n\xFAmero y ha conseguido tomar la ciudad costera completamente, ahora
        necesitamos reorganizarnos fuera de la ciudad y organizar una defensa, han
        llegado refuerzos desde la capital, que ser\xE1 el siguiente objetivo enemigo.\n\nAhora
        puedes mejorar las torres a nivel 3."
      objectReference: {fileID: 0}
