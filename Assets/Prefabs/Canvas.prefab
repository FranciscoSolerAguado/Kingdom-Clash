  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Bienvenido a Kingdom Clash\n\nTras meses intensos de guerra con el Reino
    vecino, las tropas enemigas han conseguido desembarcar en las orillas de la provincia
    de la capital del Reino, tu misi\xF3n es liderar una defensa para repeler al
    enemigo.\n\nConstruye torres con las ranuras de construcci\xF3n que encontraras
    por el campo de batalla (Imagen 1).\n\nDespliega unidades con el menu de abajo
    a la izquierda (Imagen 2), estas unidades se desbloquearan conforme avance la
    defensa al construir torres.\n\nEl reino nos permite desplegar una unidad especial
    llamada Minero, que recolectar\xE1 oro durante la batalla."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: bff15d008b8709f4c8ade535ddaee0f1, type: 2}
  m_sharedMaterial: {fileID: 742601865599858515, guid: bff15d008b8709f4c8ade535ddaee0f1, type: 2}
